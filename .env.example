# Copy this file to ".env" and fill in the two REQUIRED values:
#   cp .env.example .env
# Everything else is optional and has a safe default.


# REQUIRED. Bot token from @BotFather. Treat it like a password.
BOT_TOKEN=""

# REQUIRED. The channel to post in. Use the numeric id (recommended) or @username:
#   numeric:  -1001234567890       username:  @mychannel
# The bot must be an admin in that channel with "Post messages" AND
# "Delete messages" rights. Do NOT use a t.me invite link here.
# To find the numeric id: post any message in the channel, then open
#   https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates  and read "chat":{"id":...}.
CHANNEL_CHAT_ID=""


# ---- optional (leave blank to use the default) -------------------------

# Public link shown in the /start reply, e.g. https://t.me/yourchannel
CHANNEL_PUBLIC_URL=""

# Timezone for all post times. Any IANA name. Default: UTC.
TZ_NAME="Africa/Cairo"

# Your numeric Telegram user id (e.g. 55124, NOT a @username) to unlock the
# /admin commands in DM. The number never changes, even if you rename
# yourself, so it stays valid. Find it by messaging @userinfobot.
ADMIN_TELEGRAM_ID=""

# Runtime mode. "production" quietens debug logs; anything else means dev.
# Leave this as production: `pnpm dev` already forces development on its
# own, so this value is only used by `pnpm start` (your deploy) and the
# scripts, where production is what you want.
NODE_ENV="production"

# Port for the /health endpoint. Default: 8080.
PORT=""

# Where the small pointer file is kept. Default: ./data/last-message-ids.json
STATE_FILE=""
